# Open Audio Studio environment template. Copy to .env and fill in.

# Core
OAS_DATA_DIR=./data
OAS_DB_URL=sqlite:///./data/oas.db
OAS_LOG_LEVEL=INFO

# Server
OAS_SERVER_HOST=0.0.0.0
OAS_SERVER_PORT=8000
OAS_CORS_ORIGINS=http://localhost:3000

# Web
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Integrations (optional)
HF_TOKEN=
WANDB_API_KEY=
OPENAI_API_KEY=
